# backend/.env

# local | staging | production
ENVIRONMENT=local
PROJECT_NAME="Car Sales"
API_V1_STR=/api/v1

# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changethis
REFRESH_SECRET_KEY=changethis

ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# База данных
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis
POSTGRES_DB=car_sales

# Пул соединений
# 4 workers * (pool_size + max_overflow) < PG_MAX_CONNECTIONS - 10
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=5
DB_POOL_RECYCLE=3600

# asyncpg | psycopg
DB_DRIVER=asyncpg

# SSL mode for asyncpg: disable | allow | prefer | require | verify-ca | verify-full
# NOTE: rloop does not implement SSL in create_connection
#       If you need SSL (managed DBs), switch to --loop uvloop in scripts/start.sh.
DB_SSL_MODE=disable

# тюнинг постгри
# для 16 gb ram
PG_MAX_CONNECTIONS=200
PG_SHARED_BUFFERS=4GB
PG_EFFECTIVE_CACHE_SIZE=12GB
PG_WORK_MEM=32MB
PG_MAINTENANCE_WORK_MEM=512MB
PG_WAL_BUFFERS=64MB
PG_RANDOM_PAGE_COST=1.1
PG_EFFECTIVE_IO_CONCURRENCY=200
PG_CHECKPOINT_COMPLETION_TARGET=0.9
PG_LOG_MIN_DURATION_STATEMENT=100
# для 4 gb ram
# PG_MAX_CONNECTIONS=100
# PG_SHARED_BUFFERS=512MB
# PG_EFFECTIVE_CACHE_SIZE=2GB
# PG_WORK_MEM=8MB
# PG_MAINTENANCE_WORK_MEM=128MB
# PG_WAL_BUFFERS=16MB

# Доверять заголовку X-Forwarded-For для определения IP клиента (при reverse proxy)
TRUST_PROXY_HEADERS=false

# PgBouncer
USE_PGBOUNCER=false
PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=6432
# При USE_PGBOUNCER=true
# DB_POOL_SIZE=3
# DB_MAX_OVERFLOW=2

# Cache
CACHE_ENABLED=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=changethis
REDIS_USE_TLS=false
REDIS_MAX_CONNECTIONS=20

# AI Service Setup
AI_BACKEND=local
OLLAMA_LOCAL_URL=http://host.docker.internal:11434
OLLAMA_DOCKER_URL=http://ollama:11434

# Имеет приоритет над AI_BACKEND
#OLLAMA_BASE_URL=

AI_MODEL_NAME=qwen3.5:0.8b

# Таймауты соединения
AI_REQUEST_TIMEOUT_SEC=120.0
AI_CONNECT_TIMEOUT_SEC=10.0
AI_WRITE_TIMEOUT_SEC=30.0
AI_POOL_TIMEOUT_SEC=10.0

# Параметры генерации
AI_TEMPERATURE=0.4
AI_NUM_PREDICT=1024
AI_NUM_CTX=4096
AI_MAX_TOOL_CALL_ROUNDS=5
AI_MAX_HISTORY_MESSAGES=10

# Rate limiting
AI_MAX_REQUESTS_PER_MINUTE=5
AI_RATE_LIMIT_WINDOW_SEC=60

# Параметры инструментов
AI_TOOL_DB_TIMEOUT_SEC=10.0
AI_TOOL_MAX_RESULTS=10

# Первый суперюзер
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis
FIRST_SUPERUSER_FULL_NAME="System Administrator"

# Хранилище (local или minio)
STORAGE_BACKEND=minio

# Локальное хранилище (при STORAGE_BACKEND=local)
UPLOAD_DIR=uploads

# MinIO (при STORAGE_BACKEND=minio)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=car-sales
MINIO_SECURE=false
MINIO_PUBLIC_URL=http://localhost:9000

# Обработка изображений при загрузке
MAX_IMAGE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
IMAGE_MAX_DIMENSION=1920
IMAGE_THUMB_DIMENSION=640
IMAGE_MAX_PIXELS_MP=30
IMAGE_JPEG_QUALITY=85
IMAGE_THUMB_QUALITY=75

# Лимиты количества изображений
IMAGE_MAX_PER_CAR=20
IMAGE_MIN_PER_OFFER=3
IMAGE_MAX_PER_OFFER=20

# Пагинация
PAGINATION_DEFAULT_LIMIT=20
PAGINATION_MAX_LIMIT=100

# Marketplace: листинги / резервации
MAX_ACTIVE_LISTINGS=5
LISTING_LIFETIME_DAYS=30
RESERVATION_HOLD_DAYS=5                  # 1..7 (YooKassa two-stage hold capped at 7d)
RESERVATION_DEPOSIT_AMOUNT=5000          # рубли — фиксированный возвращаемый депозит
DEPOSIT_PAYMENT_TTL_MINUTES=30           # окно ожидания подтверждения холда; иначе авто-отмена
OUTCOME_PROMPT_INTERVAL_HOURS=24         # частота напоминаний "состоялась ли сделка?"
OUTCOME_CORRECTION_HOURS=24              # окно коррекции результата (capped by hold_deadline)
MAX_FAVORITES=300                        # лимит избранных на пользователя

# Anti-abuse (per-buyer cap + early-cancel cooldown + escalating refund delay)
MAX_ACTIVE_RESERVATIONS_PER_BUYER=2
EARLY_CANCEL_WINDOW_SECONDS=600          # cancel-within-this from created_at → cooldown
EARLY_CANCEL_COOLDOWN_SECONDS=86400      # cooldown duration on reserve_cooldown:{buyer_id}
REFUND_DELAY_WINDOW_SECONDS=2592000      # 30d sliding window for cancel-count
REFUND_DELAY_TIERS_SECONDS=0,3600,21600,86400,259200  # 0/1h/6h/24h/72h per count

# Frontend base URL — backend-mediated YooKassa return redirects here
FRONTEND_BASE_URL=http://localhost:5173

# Гео-справочник (сколько городов по population помечаются is_popular=true для UI dropdown)
CITIES_POPULAR_LIMIT=15

# Публичный браузинг (rate limit per IP)
PUBLIC_BROWSE_RATE_LIMIT=120
PUBLIC_BROWSE_RATE_WINDOW=60

# YooKassa — используется только для двухстадийного холда депозита (capture=false).
# Safe Deal (deal/payout/refund) сохранён в коде, но не подключён к flow.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://example.com/api/v1/payments/return  # backend-mediated 303→FRONTEND_BASE_URL/payment/return

# SMS / Exolve (fake|exolve)
SMS_BACKEND=fake
EXOLVE_API_KEY=
EXOLVE_FROM_NUMBER=
EXOLVE_BASE_URL=https://api.exolve.ru

# OTP
OTP_TTL_SECONDS=600
OTP_COOLDOWN_SECONDS=60
OTP_LOCKOUT_SECONDS=900
OTP_MAX_ATTEMPTS=3
OTP_MAX_DAILY=5

# Background scheduler (APScheduler + Redis leader-lock)
SCHEDULER_ENABLED=true
SCHEDULER_RELEASE_EXPIRED_INTERVAL_SECONDS=300    # отменяет просроченные холды/брошенные оплаты
SCHEDULER_FINALIZE_SETTLING_INTERVAL_SECONDS=300  # закрывает settling по correction_deadline
SCHEDULER_OUTCOME_PROMPTS_INTERVAL_SECONDS=1800   # рассылка напоминаний об исходе после просмотра
SCHEDULER_EXPIRE_LISTINGS_INTERVAL_SECONDS=3600   # активные → archived после expires_at
SCHEDULER_RECONCILE_DEPOSITS_INTERVAL_SECONDS=300 # дожимает отложенные cancel_hold вызовы

# image tags
POSTGRES_IMAGE_TAG=17-alpine
REDIS_IMAGE_TAG=7-alpine
OLLAMA_IMAGE_TAG=latest
MINIO_IMAGE_TAG=latest
MINIO_MC_IMAGE_TAG=latest

# Backend
BACKEND_WORKERS=4

# Ресурсы под AI
OLLAMA_MEM_LIMIT=10g
OLLAMA_MEMSWAP_LIMIT=10g

REDIS_MAX_MEMORY=256mb

# CORS
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# Sentry
SENTRY_DSN=
# Optional override (defaults to ENVIRONMENT above)
SENTRY_ENVIRONMENT=
# Optional: CI sets this to the git SHA via Dockerfile ARG GIT_SHA at build
SENTRY_RELEASE=
# Performance traces
SENTRY_TRACES_SAMPLE_RATE=0.0
# Continuous profiler
SENTRY_PROFILES_SAMPLE_RATE=0.0
# Production wont start if this is True
SENTRY_SEND_DEFAULT_PII=false
