# ── Production .env template for a 4 GB RAM / 30 GB disk server ──────────────
# Copy to .env, fill in all CHANGEME values, then start with:
#   docker compose -f compose.yml -f compose.prod.yml up -d --build

ENVIRONMENT=production
PROJECT_NAME="Car Sales"
API_V1_STR=/api/v1

# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGEME
REFRESH_SECRET_KEY=CHANGEME

ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=car_sales

# ── Connection pool (2 workers × pool_size + max_overflow < max_connections) ──
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=5
DB_POOL_RECYCLE=3600
DB_DRIVER=asyncpg
DB_SSL_MODE=disable

# ── PostgreSQL tuning for 4 GB RAM ───────────────────────────────────────────
PG_MAX_CONNECTIONS=100
PG_SHARED_BUFFERS=512MB
PG_EFFECTIVE_CACHE_SIZE=2GB
PG_WORK_MEM=8MB
PG_MAINTENANCE_WORK_MEM=128MB
PG_WAL_BUFFERS=16MB
PG_RANDOM_PAGE_COST=1.1
PG_EFFECTIVE_IO_CONCURRENCY=200
PG_CHECKPOINT_COMPLETION_TARGET=0.9
PG_LOG_MIN_DURATION_STATEMENT=100

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_USE_TLS=false
REDIS_MAX_CONNECTIONS=50
REDIS_MAX_MEMORY=256mb

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGEME
MINIO_SECRET_KEY=CHANGEME
MINIO_BUCKET=car-sales
MINIO_SECURE=false
# Public URL used by browsers to load images.
# Replace with your actual domain or server IP:
MINIO_PUBLIC_URL=http://CHANGEME/minio

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_WORKERS=2
TRUST_PROXY_HEADERS=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# Replace with your actual domain:
BACKEND_CORS_ORIGINS="http://CHANGEME"
FRONTEND_BASE_URL=http://CHANGEME

# ── First superuser ───────────────────────────────────────────────────────────
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=CHANGEME
FIRST_SUPERUSER_FULL_NAME="System Administrator"

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=minio
UPLOAD_DIR=uploads

# ── Image processing ──────────────────────────────────────────────────────────
MAX_IMAGE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
IMAGE_MAX_DIMENSION=1920
IMAGE_THUMB_DIMENSION=640
IMAGE_MAX_PIXELS_MP=30
IMAGE_JPEG_QUALITY=85
IMAGE_THUMB_QUALITY=75
IMAGE_MAX_PER_CAR=20
IMAGE_MIN_PER_OFFER=3
IMAGE_MAX_PER_OFFER=20

# ── Pagination ────────────────────────────────────────────────────────────────
PAGINATION_DEFAULT_LIMIT=20
PAGINATION_MAX_LIMIT=100

# ── Marketplace ───────────────────────────────────────────────────────────────
MAX_ACTIVE_LISTINGS=5
LISTING_LIFETIME_DAYS=30
RESERVATION_HOLD_DAYS=5
RESERVATION_DEPOSIT_AMOUNT=5000
DEPOSIT_PAYMENT_TTL_MINUTES=30
OUTCOME_PROMPT_INTERVAL_HOURS=24
OUTCOME_CORRECTION_HOURS=24
MAX_FAVORITES=300

# ── Anti-abuse ────────────────────────────────────────────────────────────────
MAX_ACTIVE_RESERVATIONS_PER_BUYER=2
EARLY_CANCEL_WINDOW_SECONDS=600
EARLY_CANCEL_COOLDOWN_SECONDS=86400
REFUND_DELAY_WINDOW_SECONDS=2592000
REFUND_DELAY_TIERS_SECONDS=0,3600,21600,86400,259200

# ── Rate limiting ─────────────────────────────────────────────────────────────
PUBLIC_BROWSE_RATE_LIMIT=120
PUBLIC_BROWSE_RATE_WINDOW=60
CITIES_POPULAR_LIMIT=15

# ── YooKassa (optional — needed only if using payment deposits) ───────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://CHANGEME/api/v1/payments/return

# ── SMS / Exolve (optional) ───────────────────────────────────────────────────
SMS_BACKEND=fake
EXOLVE_API_KEY=
EXOLVE_FROM_NUMBER=
EXOLVE_BASE_URL=https://api.exolve.ru

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=600
OTP_COOLDOWN_SECONDS=60
OTP_LOCKOUT_SECONDS=900
OTP_MAX_ATTEMPTS=3
OTP_MAX_DAILY=5

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_ENABLED=true

# ── Background scheduler ──────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_RELEASE_EXPIRED_INTERVAL_SECONDS=300
SCHEDULER_FINALIZE_SETTLING_INTERVAL_SECONDS=300
SCHEDULER_OUTCOME_PROMPTS_INTERVAL_SECONDS=1800
SCHEDULER_EXPIRE_LISTINGS_INTERVAL_SECONDS=3600
SCHEDULER_RECONCILE_DEPOSITS_INTERVAL_SECONDS=300

# ── AI (disabled — Ollama not used on 4 GB server) ───────────────────────────
# To enable AI: uncomment and use docker-ai profile (requires separate server)
# AI_BACKEND=local
# OLLAMA_BASE_URL=http://your-ai-server:11434
AI_MODEL_NAME=qwen2.5:3b
AI_REQUEST_TIMEOUT_SEC=120.0
AI_CONNECT_TIMEOUT_SEC=10.0
AI_WRITE_TIMEOUT_SEC=30.0
AI_POOL_TIMEOUT_SEC=10.0
AI_TEMPERATURE=0.4
AI_NUM_PREDICT=1024
AI_NUM_CTX=4096
AI_MAX_TOOL_CALL_ROUNDS=5
AI_MAX_HISTORY_MESSAGES=10
AI_MAX_REQUESTS_PER_MINUTE=5
AI_RATE_LIMIT_WINDOW_SEC=60
AI_TOOL_DB_TIMEOUT_SEC=10.0
AI_TOOL_MAX_RESULTS=10

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false

# ── Docker image tags ─────────────────────────────────────────────────────────
POSTGRES_IMAGE_TAG=17-alpine
REDIS_IMAGE_TAG=7-alpine
MINIO_IMAGE_TAG=latest
MINIO_MC_IMAGE_TAG=latest
